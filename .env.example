DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# 购买咨询
CONTACT_INFO=选套餐 → 扫码付款 → 我已付款 → 发送通知 → 管理员确认后自动开通
SITE_URL=www.kjdsai.cn

# 半自动收款（推荐）：true=提交订单后管理员确认收款，自动开通/升级，无邀请码数量限制
MANUAL_PAYMENT_ORDERS=true

# 发码邮件（QQ 邮箱示例）
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_smtp_user@example.com
SMTP_PASS=your_smtp_app_password
SMTP_FROM=跨境AI Listing <your_smtp_user@example.com>

# 新订单通知发到这个邮箱（用户无需填邮箱）
ADMIN_NOTIFY_EMAIL=your_admin@example.com
# 邮件确认收款密钥（务必改成随机长字符串；用于签名短时确认链接）
ADMIN_FULFILL_TOKEN=replace-with-long-random-string
# 是否同时自动发用户邮箱（默认 false，用户无需邮箱）
NOTIFY_USER_EMAIL=false

# 微信通知（可选，注册 PushPlus 免费：https://www.pushplus.plus ）
PUSHPLUS_TOKEN=
# 或 Server酱 SendKey（可选）
SERVERCHAN_SENDKEY=

# 页面左侧「联系客服」弹窗
CONTACT_WECHAT_QR=/assets/payment/wechat-service.png
CONTACT_WECHAT_ID=your_wechat_id
CONTACT_EMAIL=your_admin@example.com

# 收款码（开通会员弹窗）
PAYMENT_WECHAT_QR=/assets/payment/wechat-pay.png
PAYMENT_ALIPAY_QR=/assets/payment/alipay-pay.png

# 以下激活码/升级码仅在 MANUAL_PAYMENT_ORDERS=false 时使用；手动收款模式下可留空
# 月卡 ¥29.9 / 半年卡 ¥69.9 / 年卡 ¥129.9
ACTIVATION_CODES_MONTH=
ACTIVATION_CODES_HALF=
ACTIVATION_CODES_YEAR=

# 兼容旧版激活码（按年卡 365 天处理）
ACTIVATION_CODES=

# 升级邀请码（仅 MANUAL_PAYMENT_ORDERS=false 时使用）
UPGRADE_CODES_HALF=
UPGRADE_CODES_YEAR=

# 百度搜索推送（在 https://ziyuan.baidu.com 验证站点后获取）
# BAIDU_PUSH_SITE=www.kjdsai.cn
# BAIDU_PUSH_TOKEN=your_baidu_push_token
