DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# 购买咨询
CONTACT_INFO=选套餐 → 提交订单 → 付款备注订单号 → 等待邀请码出现
SITE_URL=www.kjdsai.cn

# 半自动收款：true=提交订单后等你确认收款再发码；false=恢复旧的自助领码（不推荐）
MANUAL_PAYMENT_ORDERS=true

# 发码邮件（QQ 邮箱示例）
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=108729447@qq.com
SMTP_PASS=你的QQ邮箱授权码
SMTP_FROM=跨境AI Listing <108729447@qq.com>

# 新订单通知发到这个邮箱（用户无需填邮箱）
ADMIN_NOTIFY_EMAIL=108729447@qq.com
# 邮件里一键确认收款的密钥（自行设置一串随机字符）
ADMIN_FULFILL_TOKEN=请改成随机字符串
# 是否同时自动发用户邮箱（默认 false，用户无需邮箱）
NOTIFY_USER_EMAIL=false

# 微信通知（可选，注册 PushPlus 免费：https://www.pushplus.plus ）
PUSHPLUS_TOKEN=
# 或 Server酱 SendKey（可选）
SERVERCHAN_SENDKEY=

# 页面左侧「联系客服」弹窗
CONTACT_WECHAT_QR=/assets/payment/wechat-service.png
CONTACT_WECHAT_ID=你的微信号
CONTACT_EMAIL=108729447@qq.com

# 收款码（开通会员弹窗）
PAYMENT_WECHAT_QR=/assets/payment/wechat-pay.png
PAYMENT_ALIPAY_QR=/assets/payment/alipay-pay.png

# 会员激活码（逗号分隔，按套餐分别配置，付款核实后发给用户）
# 月卡 ¥29.9 / 半年卡 ¥69.9 / 年卡 ¥129.9
ACTIVATION_CODES_MONTH=LISTING-M29-001,LISTING-M29-002
ACTIVATION_CODES_HALF=LISTING-H69-001,LISTING-H69-002
ACTIVATION_CODES_YEAR=LISTING-Y129-001,LISTING-Y129-002

# 兼容旧版激活码（按年卡 365 天处理）
ACTIVATION_CODES=PRO-LISTING-2024,PRO-VIP-8888,XLBVIP

# 升级邀请码（补差价后自动发放，按目标套餐配置）
UPGRADE_CODES_HALF=UPGRADE-H40-001,UPGRADE-H40-002
UPGRADE_CODES_YEAR=UPGRADE-Y100-001,UPGRADE-Y100-002
